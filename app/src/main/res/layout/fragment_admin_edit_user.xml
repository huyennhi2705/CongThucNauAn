<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════ -->
        <!--              HEADER                    -->
        <!-- ══════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="16dp"
            android:paddingTop="48dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/btn_icon_bg"
                android:contentDescription="Quay lại"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="sans-serif-medium"
                android:text="Sửa người dùng"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- ══════════════════════════════════════ -->
        <!--           AVATAR SECTION               -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- Avatar with edit overlay -->
            <FrameLayout
                android:id="@+id/frameAvatarEdit"
                android:layout_width="88dp"
                android:layout_height="88dp">

                <!-- Avatar circle / image -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/ic_default_avatar"
                    app:civ_border_color="#E8631A"
                    app:civ_border_width="2dp" />


                <FrameLayout
                    android:id="@+id/frameInitials"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_avatar_circle_large"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Camera edit button -->
                <ImageView
                    android:id="@+id/btnCamera"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_btn_camera"
                    android:contentDescription="Đổi ảnh"
                    android:padding="5dp"
                    android:src="@drawable/ic_camera"
                   />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="Nhấn để đổi ảnh đại diện"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0" />

        <!-- ══════════════════════════════════════ -->
        <!--            FORM FIELDS                 -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <!-- Họ và tên -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Họ và tên"
                android:textColor="#555555"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:boxBackgroundColor="#FFF8F5"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxStrokeColor="#E8631A"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="10dp"
                    android:drawableTint="#E8631A"
                    android:fontFamily="sans-serif-medium"
                    android:hint="Nhập họ và tên"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="14dp"
                    android:textColor="#2D2D2D"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Email"
                android:textColor="#555555"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:boxBackgroundColor="#FFF8F5"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxStrokeColor="#E8631A"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="10dp"
                    android:drawableTint="#E8631A"
                    android:fontFamily="sans-serif-medium"
                    android:hint="Nhập email"
                    android:inputType="textEmailAddress"
                    android:paddingStart="14dp"
                    android:textColor="#2D2D2D"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Số điện thoại -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Số điện thoại"
                android:textColor="#555555"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                app:boxBackgroundColor="#FFF8F5"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusTopStart="10dp"
                app:boxStrokeColor="#E8631A"
                app:hintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="10dp"
                    android:drawableTint="#E8631A"
                    android:fontFamily="sans-serif-medium"
                    android:hint="Nhập số điện thoại"
                    android:inputType="phone"
                    android:paddingStart="14dp"
                    android:textColor="#2D2D2D"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Vai trò -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Vai trò"
                android:textColor="#555555"
                android:textSize="12sp" />

            <RadioGroup
                android:id="@+id/rgRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbUser"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_role_selector"
                    android:button="@null"
                    android:checked="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Người dùng"
                    android:textColor="@color/role_text_selector"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbAdmin"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_role_selector"
                    android:button="@null"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Quản trị viên"
                    android:textColor="@color/role_text_selector"
                    android:textSize="13sp" />

            </RadioGroup>

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--          READ-ONLY INFO CARD           -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#FFF8F5"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- UID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:drawableStart="@drawable/ic_finger"
                        android:drawablePadding="6dp"
                        android:drawableTint="#E8631A"
                        android:fontFamily="sans-serif-medium"
                        android:text="UID"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvUid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:fontFamily="sans-serif-medium"
                        android:maxWidth="180dp"
                        android:singleLine="true"
                        android:text="abc123xyz"
                        android:textColor="#2D2D2D"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginBottom="10dp"
                    android:background="#EEEEEE" />

                <!-- Avatar URL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:drawableStart="@drawable/ic_image"
                        android:drawablePadding="6dp"
                        android:drawableTint="#E8631A"
                        android:fontFamily="sans-serif-medium"
                        android:text="Avatar URL"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvAvatarUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="middle"
                        android:fontFamily="sans-serif-medium"
                        android:maxWidth="160dp"
                        android:singleLine="true"
                        android:text="https://..."
                        android:textColor="#2D2D2D"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginBottom="10dp"
                    android:background="#EEEEEE" />

                <!-- Ngày tạo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#E8631A"
                        android:fontFamily="sans-serif-medium"
                        android:text="Ngày tạo"
                        android:textColor="#888888"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvCreatedAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="12/03/2024 09:45"
                        android:textColor="#2D2D2D"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_secondary"
                android:fontFamily="sans-serif-medium"
                android:text="Hủy"
                android:textColor="#888888"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="2"
                android:background="@drawable/bg_btn_primary"
                android:drawableEnd="@drawable/ic_save"
                android:drawablePadding="8dp"
                android:drawableTint="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:text="Lưu thay đổi"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--          DELETE ACCOUNT BUTTON         -->
        <!-- ══════════════════════════════════════ -->
        <Button
            android:id="@+id/btnDeleteAccount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_btn_danger_outline"
            android:drawableStart="@drawable/ic_delete"
            android:drawablePadding="8dp"
            android:drawableTint="#D32F2F"
            android:fontFamily="sans-serif-medium"
            android:text="Xóa tài khoản này"
            android:textColor="#D32F2F"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>