<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0"
    android:orientation="vertical">

    <!-- ══════════════════════════════════════ -->
    <!--              HEADER  (fixed layout)    -->
    <!-- ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="48dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Back button – KÍCH thước cố định, không stretch -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/btn_icon_bg"
            android:contentDescription="Quay lại"
            android:src="@drawable/ic_arrow_back" />

        <!-- Title – fill phần còn lại giữa 2 view -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Quản lý người dùng"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- User count badge – cùng hàng, không đè nhau -->
        <TextView
            android:id="@+id/tvUserCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:background="@drawable/badge_circle_white"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingEnd="10dp"
            android:paddingBottom="4dp"
            android:text="0 người dùng"
            android:textColor="#E8631A"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════ -->
    <!--            SEARCH BAR                  -->
    <!-- ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search_bar"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:drawableTint="#BBBBBB"
            android:fontFamily="sans-serif-medium"
            android:hint="Tìm tên, email hoặc số điện thoại..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#2D2D2D"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════ -->
    <!--          PROGRESS                      -->
    <!-- ══════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="40dp"
        android:indeterminateTint="#E8631A"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════ -->
    <!--          EMPTY STATE                   -->
    <!-- ══════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="😕 Không có người dùng nào"
        android:textColor="#AAAAAA"
        android:textSize="15sp"
        android:visibility="gone" />

    <!-- ══════════════════════════════════════ -->
    <!--          RECYCLER VIEW                 -->
    <!-- ══════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerUsers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>