<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.home.HomeFragment"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:background="#F4F6FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ===== HEADER BANNER ===== -->
        <RelativeLayout
            android:id="@+id/layoutTop"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_header_gradient"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="2dp"
                app:shapeAppearanceOverlay="@style/ShapeCircle"
                app:strokeColor="@color/colorBluePrimary"
                app:strokeWidth="2dp"
                android:elevation="4dp"/>

            <!-- Welcome text -->
            <TextView
                android:id="@+id/textWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageAvatar"
                android:layout_marginStart="14dp"
                android:layout_marginTop="4dp"
                android:text="Welcome back 👋"
                android:textColor="#CCE8F4"
                android:textSize="13sp"
                android:letterSpacing="0.03"/>

            <!-- Username -->
            <TextView
                android:id="@+id/textUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageAvatar"
                android:layout_below="@id/textWelcome"
                android:layout_marginStart="14dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="17sp"
                android:letterSpacing="0.01"/>

            <!-- Notification icon -->
            <ImageView
                android:id="@+id/imageNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="false"
                android:padding="8dp"
                android:src="@drawable/ic_thongbao"
                android:background="@drawable/bg_icon_circle"
                android:tint="#FFFFFF"/>

            <!-- Search bar -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchPlace"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@null"/>

            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <!-- ===== RECOMMENDED SECTION ===== -->
        <LinearLayout
            android:id="@+id/layoutTextRecommended"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutTop">

            <TextView
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Recommended for you"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:letterSpacing="0.01"/>

            <TextView
                android:id="@+id/textViewRecommended"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View all →"
                android:textColor="@color/colorBluePrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="2dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRecommended"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutTextRecommended"/>

        <!-- ===== CATEGORY SECTION ===== -->
        <LinearLayout
            android:id="@+id/layoutTextCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/recyclerRecommended">

            <TextView
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#1A1A2E"
                android:letterSpacing="0.01"/>

            <TextView
                android:id="@+id/textViewCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View all →"
                android:textColor="@color/colorBluePrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingTop="2dp"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCategory"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="12dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutTextCategory"/>

        <!-- ===== MORE TRIPS SECTION ===== -->
        <TextView
            android:id="@+id/textViewMoreTrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/recyclerCategory"
            android:text="More Trips for you"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1A1A2E"
            android:letterSpacing="0.01"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMoreTrip"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewMoreTrip"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>